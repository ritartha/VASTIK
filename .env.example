# Django
DEBUG=True
SECRET_KEY=change-me-to-a-real-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL) — Railway provides this automatically
DATABASE_URL=postgres://vastik_user:vastik_pass@localhost:5432/vastik_db

# CORS — comma-separated origins
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# CSRF Trusted Origins (for production with HTTPS)
CSRF_TRUSTED_ORIGINS=https://your-app.railway.app

# Django Settings Module
DJANGO_SETTINGS_MODULE=vastik.settings.production

# Social Links (update with your real URLs)
